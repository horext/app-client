{
  "name": "horext-ssr-client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "lint:js": "eslint .",
    "lint:prettier": "prettier --check --ignore-path .gitignore \"**/*.{js,ts,vue}\"",
    "lint": "yarn lint:js && yarn lint:prettier",
    "lint:fix": "prettier --write --ignore-path .gitignore \"**/*.{js,ts,vue}\" && pnpm lint:js --fix",
    "test:unit": "vitest",
    "test:unit:cov": "vitest --coverage",
    "test:unit:ci": "vitest run --coverage",
    "test:types": "nuxi prepare && vue-tsc --noEmit",
    "bench": "vitest bench --run --project=bench --outputJson=.bench/results-baseline.json",
    "bench-compare": "vitest bench --run --project=bench --compare=.bench/results-baseline.json",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@nuxt/image": "^2.0.0",
    "@pinia/nuxt": "^0.11.3",
    "@unhead/vue": "^3.1.0",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "google-auth-library": "^10.6.2",
    "html2canvas-pro": "^2.0.2",
    "idb": "^8.0.3",
    "jspdf": "^4.2.1",
    "lottie-web": "^5.13.0",
    "luxon": "^3.7.2",
    "ofetch": "^1.5.1",
    "pinia": "^3.0.4",
    "ufo": "^1.6.4",
    "unhead": "^3.1.0",
    "unstorage": "^1.17.5",
    "uuid": "^14.0.0",
    "vite": "^8.0.14",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "vuetify": "^4.0.8"
  },
  "devDependencies": {
    "@mdi/js": "^7.4.47",
    "@nuxt/devtools": "4.0.0-alpha.4",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/scripts": "^1.1.0",
    "@nuxt/test-utils": "^4.0.3",
    "@types/google.accounts": "^0.0.18",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.9.1",
    "@types/uuid": "^11.0.0",
    "@unhead/schema": "^3.1.0",
    "@unocss/nuxt": "^66.7.0",
    "@unocss/preset-wind4": "^66.7.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-nuxt": "^4.0.0",
    "eslint-plugin-vue": "^10.9.1",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.5",
    "nitropack": "^2.13.4",
    "nuxt": "^4.4.6",
    "nuxt-gtag": "^4.1.0",
    "playwright-core": "^1.60.0",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "typescript": "^6.0.3",
    "unocss": "^66.7.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.1"
  }
}
